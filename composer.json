{
    "name": "flute-cms/cms",
    "description": "CMS for gaming servers",
    "version": "v0.4.0-dev",
    "type": "project",
    "keywords": [
        "cms",
        "flute",
        "flute engine"
    ],
    "authors": [
        {
            "name": "Flames",
            "email": "xenozf@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "require": {
        "monolog/monolog": "^2.9",
        "league/config": "^1.2",
        "eftec/bladeone": "^4.13",
        "symfony/routing": "^6.1",
        "symfony/http-foundation": "^6.4",
        "symfony/event-dispatcher": "^6.4",
        "symfony/http-kernel": "^6.0",
        "symfony/translation": "^6.4",
        "symfony/cache": "^6.4",
        "scssphp/scssphp": "^1.13",
        "cycle/orm": "v2.8.0",
        "matthiasmullie/minify": "^1.3",
        "hybridauth/hybridauth": "^3.11",
        "whichbrowser/parser": "v2.1.8",
        "nette/forms": "^3.2",
        "symfony/mime": "^6.4",
        "rosell-dk/webp-convert": "^2.9",
        "php-di/php-di": "^7.0",
        "symfony/filesystem": "^6.4",
        "composer/composer": "^2.7",
        "tracy/tracy": "^2.10",
        "xpaw/php-source-query-class": "^4.0",
        "xpaw/steamid": "^3.0",
        "hiqdev/omnipay-freekassa": "dev-master",
        "omnipay/stripe": "^3.2",
        "dercoder/omnipay-webmoney": "^5.0",
        "omnipay/paypal": "^3.0",
        "nesbot/carbon": "3.8.0",
        "symfony/mailer": "^6.1",
        "guzzlehttp/guzzle": "v7.9.2",
        "php-http/guzzle7-adapter": "^1.0",
        "league/omnipay": "^3.2",
        "symfony/process": "v6.4.8",
        "symfony/string": "v6.4.10",
        "doctrine/collections": "^2.2",
        "cycle/annotated": "^4.1",
        "cycle/schema-builder": "^2.9",
        "cycle/migrations": "^4.2"
    },
    "autoload": {
        "psr-4": {
            "Flute\\": "app/"
        }
    }
}
