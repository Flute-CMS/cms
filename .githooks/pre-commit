#!/usr/bin/env bash

set -e

echo "🔍 Pre-commit checks..."

if [ ! -x "vendor/bin/mago" ]; then
    echo "⚠️  Mago not found, skipping checks"
    exit 0
fi

echo "  ⏳ Mago lint..."
vendor/bin/mago lint --minimum-fail-level=error
echo "  ✔ Lint passed"

echo "  ⏳ Mago format check..."
if ! vendor/bin/mago format --check > /dev/null 2>&1; then
    echo "  🔧 Auto-formatting..."
    vendor/bin/mago format > /dev/null 2>&1
    git diff --name-only -- '*.php' | while read -r f; do
        git add "$f"
    done
    echo "  ✔ Formatted and re-staged"
else
    echo "  ✔ Format OK"
fi

echo "  ⏳ Mago analyze..."
vendor/bin/mago analyze
echo "  ✔ Analysis passed"

echo "✅ All checks passed"
